# ── Database (Neon — use the POOLED connection string) ────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require"

# ── Auth (NextAuth / Auth.js) ─────────────────────────────────────────────────
AUTH_SECRET="generate-with: openssl rand -base64 32"
# Set to the deployment's public URL (the vercel.app URL while testing,
# the real domain after cutover)
NEXTAUTH_URL="https://your-app.vercel.app"

# ── Google Gemini (voice search + verse corrections) ──────────────────────────
GEMINI_API_KEY=""

# ── Cloudflare R2 object storage (uploads: book files/covers, audio, avatars) ──
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="eotc-media-uploads"

# ── Email (SMTP) — use an externally reachable host, not localhost ────────────
SMTP_HOST=""
SMTP_PORT="465"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="EOTC Media <no-reply@example.com>"

# ── Cron (Vercel Cron sends Authorization: Bearer ${CRON_SECRET}) ─────────────
CRON_SECRET="generate-a-random-string"
